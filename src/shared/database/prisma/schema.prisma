generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPERADMIN
  PROVIDER
  PILGRIM
}

enum VerifyStatus {
  IN_REVIEW
  VERIFIED
  REJECTED
  AUTO_CANCELED
}

enum PaymentStatus {
  PENDING
  CHECKING
  COMPLETED
}

enum PilgrimRelation {
  SELF
  SPOUSE
  FATHER
  MOTHER
  CHILD
  SIBLING
}

enum RoomType {
  DBL
  TRPL
  QUAD
  QUINT
}

model Agency {
  id                String           @id @default(uuid())
  name              String
  slug              String           @unique
  visaPrice         Decimal          @default(0) @map("visa_price")
  bankName          String?          @map("bank_name")
  bankAccountName   String?          @map("bank_account_name")
  bankAccountNumber String?          @map("bank_account_number")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  createdBy         String?          @map("created_by")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  updatedBy         String?          @map("updated_by")
  deletedAt         DateTime?        @map("deleted_at")
  deletedBy         String?          @map("deleted_by")
  users             User[]
  pilgrims          Pilgrim[]
  manifests         Manifest[]
  visaSubmissions   VisaSubmission[] @relation("AgencySubmissions")

  @@map("agencies")
}

model User {
  id                   String           @id @default(uuid())
  email                String?          @unique
  phoneNumber          String?          @unique @map("phone_number")
  password             String
  fullName             String?          @map("full_name")
  role                 UserRole         @default(PILGRIM)
  agencySlug           String?          @map("agency_slug")
  photoUrl             String?          @map("photo_url")
  agency               Agency?          @relation(fields: [agencySlug], references: [slug])
  invitationToken      String?          @map("invitation_token")
  invitationExpires    DateTime?        @map("invitation_expires")
  resetPasswordToken   String?          @map("reset_password_token")
  resetPasswordExpires DateTime?        @map("reset_password_expires")
  createdAt            DateTime         @default(now()) @map("created_at")
  createdBy            String?          @map("created_by")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  updatedBy            String?          @map("updated_by")
  deletedAt            DateTime?        @map("deleted_at")
  deletedBy            String?          @map("deleted_by")
  submissions          VisaSubmission[] @relation("LeaderSubmissions")

  @@map("users")
}

model Pilgrim {
  id             String           @id @default(uuid())
  leaderId       String           @map("leader_id")
  agencySlug     String           @map("agency_slug")
  fullName       String           @map("full_name")
  passportNumber String           @unique @map("passport_number")
  passportExpiry DateTime         @map("passport_expiry")
  birthDate      DateTime         @map("birth_date")
  gender         String
  maritalStatus  String           @map("marital_status")
  relation       PilgrimRelation  @default(SELF) @map("relation")
  nik            String           @map("nik")
  uniformSize    String?          @map("uniform_size")
  isComplete     Boolean          @default(false) @map("is_complete")
  photoUrl       String           @map("photo_url")
  ktpUrl         String           @map("ktp_url")
  passportUrl    String           @map("passport_url")
  agency         Agency           @relation(fields: [agencySlug], references: [slug])
  submissions    VisaSubmission[] @relation("SubmissionMembers")
  createdAt      DateTime         @default(now()) @map("created_at")
  createdBy      String?          @map("created_by")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  updatedBy      String?          @map("updated_by")
  deletedAt      DateTime?        @map("deleted_at")
  deletedBy      String?          @map("deleted_by")

  @@map("pilgrims")
}

model VisaSubmission {
  id              String        @id @default(uuid())
  leaderId        String        @map("leader_id")
  agencySlug      String        @map("agency_slug")
  status          VerifyStatus  @default(IN_REVIEW) @map("status")
  verifyStatus    VerifyStatus  @default(IN_REVIEW) @map("verify_status")
  verifierId      String?       @map("verifier_id")
  verifiedAt      DateTime?     @map("verified_at")
  resultSnapshot  Json?         @map("result_snapshot")
  anomalyHandled  Boolean       @default(false) @map("anomaly_handled")
  reimburseTicket String?       @unique @map("reimburse_ticket")
  replenishTicket String?       @unique @map("replenish_ticket")
  rejectionReason String?       @map("rejection_reason")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  proofOfPayment  String?       @map("proof_of_payment")
  totalAmount         Decimal       @map("total_amount")
  
  flightEta           DateTime?     @map("flight_eta")
  flightEtd           DateTime?     @map("flight_etd")
  hotelCheckin        DateTime?     @map("hotel_checkin")
  hotelCheckout       DateTime?     @map("hotel_checkout")
  transportType       String?       @map("transport_type")
  tripRoute           String?       @map("trip_route")

  flightNo            String        @map("flight_no")
  carrier             String        @map("carrier")
  flightDate          DateTime      @map("flight_date")
  hotelMakkahName     String        @map("hotel_makkah_name")
  hotelMadinahName    String        @map("hotel_madinah_name")
  hotelMakkahResvNo   String        @map("hotel_makkah_resv_no")
  hotelMadinahResvNo  String        @map("hotel_madinah_resv_no")
  roomType            RoomType      @map("room_type")
  busCompany          String        @map("bus_company")
  busTime             String        @map("bus_time")
  totalBus            Int           @map("total_bus")
  trainDate           DateTime      @map("train_date")
  trainFrom           String        @map("train_from")
  trainTo             String        @map("train_to")
  trainTime           String        @map("train_time")
  trainTotalH         Int           @map("train_total_h")
  rawdahMenTime       String        @map("rawdah_men_time")
  rawdahWomenTime     String        @map("rawdah_women_time")

  leader              User          @relation("LeaderSubmissions", fields: [leaderId], references: [id])
  agency          Agency        @relation("AgencySubmissions", fields: [agencySlug], references: [slug])
  members         Pilgrim[]     @relation("SubmissionMembers")
  createdAt       DateTime      @default(now()) @map("created_at")
  createdBy       String        @map("created_by")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  updatedBy       String?       @map("updated_by")
  deletedAt       DateTime?     @map("deleted_at")
  deletedBy       String?       @map("deleted_by")

  @@map("visa_submissions")
}

model Manifest {
  id              String    @id @default(uuid())
  agencySlug      String    @map("agency_slug")
  flightNumber    String    @map("flight_number")
  carrier         String
  departureDate   DateTime  @map("departure_date")
  arrivalDate     DateTime  @map("arrival_date")
  hotelMakkah     String    @map("hotel_makkah")
  hotelMadinah    String    @map("hotel_madinah")
  rawdahMenDate   DateTime? @map("rawdah_men_date")
  rawdahWomenDate DateTime? @map("rawdah_women_date")
  agency          Agency    @relation(fields: [agencySlug], references: [slug])
  createdAt       DateTime  @default(now()) @map("created_at")
  createdBy       String?   @map("created_by")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  updatedBy       String?   @map("updated_by")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by")

  @@map("manifests")
}
