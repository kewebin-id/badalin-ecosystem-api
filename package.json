{
  "name": "badalin-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run prisma:sync && nest build",
    "start": "nest start",
    "dev": "npm run prisma:generate && nest start --watch -r tsconfig-paths/register",
    "debug": "nest start --debug --watch -r tsconfig-paths/register",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-all": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "start:prod": "node dist/main",
    "check:lint": "eslint \"{src}/**/*.ts\" --fix",
    "check:prettier": "prettier --write \"src/**/*.ts\"",
    "check:types": "tsc --pretty --noEmit",
    "format:lint": "eslint --fix \"{src,apps,libs,test}/**/*.ts\"",
    "format:prettier": "prettier --config .prettierrc \"src/**/*.ts\" \"test/**/*.ts\" --write",
    "validate": "npm run check:prettier && npm run check:lint && npm run check:types",
    "prisma:sync": "npx prisma db push && npx prisma generate",
    "prisma:generate": "npx prisma generate --schema=src/shared/database/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=src/shared/database/prisma/schema.prisma",
    "prisma:deploy": "npx prisma migrate deploy --schema=src/shared/database/prisma/schema.prisma",
    "prisma:format": "npx prisma format --schema=src/shared/database/prisma/schema.prisma",
    "prisma:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/shared/database/seed/agency.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@supabase/supabase-js": "^2.100.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "prisma": "7.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cron": "^2.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
